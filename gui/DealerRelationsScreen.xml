<?xml version="1.0" encoding="utf-8" standalone="no" ?>

<GUI name="menuDealerRelations">
    <GuiElement profile="fs25_menuContainer">

        <GuiElement profile="fs25_menuHeaderPanel" position="-200px 90px" width="800px">
            <Text profile="fs25_menuHeaderTitle" text="Dealer Relations" id="dealerRelationsHeaderText"/>
        </GuiElement>

        <BoxLayout profile="fs25_subCategorySelectorTabbedBox" id="subCategoryBox">
            <Button profile="fs25_subCategorySelectorTabbedTab" id="drOverviewTab" text="Overview" onClick="onClickOverviewTab">
                <ThreePartBitmap profile="fs25_subCategorySelectorTabbedTabBg" name="background"/>
            </Button>
            <Button profile="fs25_subCategorySelectorTabbedTab" id="drFinancingTab" text="Financing" onClick="onClickFinancingTab">
                <ThreePartBitmap profile="fs25_subCategorySelectorTabbedTabBg" name="background"/>
            </Button>
            <Button profile="fs25_subCategorySelectorTabbedTab" id="drSettingsTab" text="Settings" onClick="onClickSettingsTab">
                <ThreePartBitmap profile="fs25_subCategorySelectorTabbedTabBg" name="background"/>
            </Button>
        </BoxLayout>

        <MultiTextOption profile="fs25_subCategorySelectorTabbed" id="subCategoryPaging" position="0px -10px" onClick="onClickSubCategoryPaging"/>

        <ScrollingLayout profile="fs25_settingsLayout" id="helpButtonLayout" position="700px -10px" size="140px 60px"/>

       <GuiElement id="overviewPanel" position="0px 100px" width="1400px" height="600px">
            <Bitmap id="dealerLogoImage" position="700px 380px" size="96px 96px"/>
            <ThreePartBitmap width="1400px" height="600px" position="0px 0px">
                <GuiElement profile="fs25_subCategoryContainer" width="1360px">

                    <Text profile="dr_textDefaultTopLeft" text="Dealer Name:" position="20px -40px" size="260px 28px"/>
                    <Text profile="dr_textDefaultTopLeft" id="dealerNameValueText" text="Dealer" position="300px -40px" size="420px 28px"/>

                    <Text profile="dr_textDefaultTopLeft" text="Dealer Hours:" position="20px -80px" size="260px 28px"/>
                    <Text profile="dr_textDefaultTopLeft" id="dealerHoursValueText" text="07:00 - 18:00" position="300px -80px" size="420px 28px"/>

                    <Text profile="dr_textDefaultTopLeft" text="Dealer Status:" position="20px -120px" size="260px 28px"/>
                    <Text profile="dr_textDefaultTopLeft" id="dealerStatusValueText" text="Closed" position="300px -120px" size="420px 28px"/>

                    <Text profile="dr_textDefaultTopLeft" text="Relationship Level:" position="20px -180px" size="260px 28px"/>
                    <Text profile="dr_textDefaultTopLeft" id="relationshipLevelValueText" text="Neutral" position="300px -180px" size="260px 28px"/>

                    <Text profile="dr_textDefaultTopLeft" text="Confidence:" position="20px -240px" size="260px 28px"/>
                    <Text profile="dr_textDefaultTopLeft" id="confidenceValueText" text="0" position="300px -240px" size="260px 28px"/>
                    
                    <Text profile="dr_textDefaultTopLeft" id="dealerActivityTitleText" text="No dealer activity." position="20px -260px" size="820px 28px"/>

                    <ScrollingLayout profile="fs25_settingsLayout" id="offerActionsLayout" position="20px -300px" size="580px 80px" visible="false"/>

                    <Text profile="dr_textDefaultTopLeft" id="dealerActivityDetail1Text" text="" position="20px -390px" size="580px 28px"/>
                    <Text profile="dr_textDefaultTopLeft" id="dealerActivityDetail2Text" text="" position="20px -430px" size="580px 28px"/>
                    <Text profile="dr_textDefaultTopLeft" id="dealerActivityDetail3Text" text="" position="20px -470px" size="580px 28px"/>
                    <Text profile="dr_textDefaultTopLeft" id="dealerActivityDetail4Text" text="" position="20px -510px" size="580px 28px"/>
                    <Text profile="dr_textDefaultTopLeft" id="dealerActivityDetail5Text" text="" position="20px -550px" size="580px 28px"/>
                    <Text profile="dr_textDefaultTopLeft" id="dealerActivityDetail6Text" text="" position="20px -590px" size="580px 28px"/>

                    <Bitmap profile="fs25_vehiclesDetailsImage" id="offerImage" position="300px -200px" size="200px 200px"/>
                </GuiElement>
            </ThreePartBitmap>
        </GuiElement>

        <GuiElement id="financingPanel" visible="false" position="0px 100px" width="1400px" height="600px">
            <ThreePartBitmap width="1400px" height="600px" position="0px 0px">
                <GuiElement profile="fs25_subCategoryContainer" width="1360px">

                    <Text profile="dr_textDefaultTopLeft" text="Credit Score:" position="20px 20px" size="200px 28px"/>
                    <Text profile="dr_textDefaultTopLeft" id="creditScoreValueText" text="" position="230px 20px" size="200px 28px"/>

                    <Text profile="dr_textDefaultTopLeft" text="Finance Rate:" position="460px 20px" size="200px 28px"/>
                    <Text profile="dr_textDefaultTopLeft" id="financeRateValueText" text="" position="670px 20px" size="160px 28px"/>

                    <GuiElement id="financeTableContainer" visible="false">
                        <GuiElement profile="fs25_statisticsHeaderBox" position="0px -20px">
                            <Button profile="dr_tableHeader" position="20px 0px"   text="Equipment"        handleFocus="false"/>
                            <Button profile="dr_tableHeader" position="460px 0px"  text="Monthly Payment"  handleFocus="false"/>
                            <Button profile="dr_tableHeader" position="740px 0px"  text="Rate"             handleFocus="false"/>
                            <Button profile="dr_tableHeader" position="920px 0px"  text="Months Left"      handleFocus="false"/>
                            <Button profile="dr_tableHeader" position="1140px 0px" text="Remaining"        handleFocus="false"/>
                        </GuiElement>

                        <SmoothList profile="dr_loanTable" id="loanTable" position="0px -60px">
                            <ListItem profile="dr_loanListItem">
                                <Text profile="dr_loanRowCell" position="20px 0px"   size="400px 32px" name="loan_name"/>
                                <Text profile="dr_loanRowCell" position="460px 0px"  size="240px 32px" name="loan_payment"/>
                                <Text profile="dr_loanRowCell" position="740px 0px"  size="140px 32px" name="loan_rate"/>
                                <Text profile="dr_loanRowCell" position="920px 0px"  size="180px 32px" name="loan_months"/>
                                <Text profile="dr_loanRowCell" position="1140px 0px" size="200px 32px" name="loan_remaining"/>
                            </ListItem>
                        </SmoothList>

                        <ThreePartBitmap profile="dr_listSlider" position="50px -60px" size="6px 440px">
                            <Slider profile="fs25_listSlider" dataElementId="loanTable"/>
                        </ThreePartBitmap>
                    </GuiElement>

                    <GuiElement id="financeNoLoansContainer" visible="false">
                        <Text profile="dr_textDefaultTopLeft" text="No active loans." position="20px -20px" size="400px 28px"/>
                    </GuiElement>

                    <ScrollingLayout profile="fs25_settingsLayout" id="loanActionsLayout" position="20px -530px" size="400px 80px" visible="false"/>

                </GuiElement>
            </ThreePartBitmap>
        </GuiElement>

        <GuiElement profile="fs25_subCategorySelectorTabbedContainer" id="settingsPanel" visible="false">
            <GuiElement profile="fs25_subCategoryContainer" width="860px">
                <Text profile="dr_textDefaultTopLeft" text="Settings" position="20px 20px" size="400px 32px"/>

                <ScrollingLayout profile="fs25_settingsLayout" id="settingsLayout" visible="true" position="20px -70px" size="820px 180px"/>

                <Text profile="dr_textDefaultTopLeft" text="Brands Filter" position="20px -270px" size="400px 28px"/>
                <ScrollingLayout id="brandsLayout" profile="fs25_settingsLayout" position="20px -310px" size="820px 385px"/>
                <ThreePartBitmap profile="dr_listSlider" position="50px -310px" size="6px 385px">
                    <Slider profile="fs25_listSlider" dataElementId="brandsLayout"/>
                </ThreePartBitmap>
            </GuiElement>
        </GuiElement>
    </GuiElement>

    <GUIProfiles>
        <Profile name="dr_textDefaultTopLeft" extends="fs25_textDefault" with="anchorTopLeft">
            <isFocusable value="false"/>
            <textSize value="18px"/>
            <textColor value="$preset_colorWhite"/>
            <textAlignment value="left"/>
        </Profile>

        <Profile name="dr_settingsButton" extends="emptyPanel" with="anchorMiddleLeft">
            <size value="280px 32px"/>
            <position value="-10px 0px"/>
            <focusOnHighlight value="true"/>
            <textResizeWidth value="200px"/>
            <textSize value="16px"/>
            <iconColor value="$preset_colorTransparent"/>
            <iconFocusedColor value="$preset_colorTransparent"/>
            <iconTextOffset value="0px -1px"/>
            <iconHighlightedColor value="$preset_colorTransparent"/>
            <textBold value="true"/>
            <textUpperCase value="true"/>
            <textAlignment value="center"/>
            <textColor value="1 1 1 1"/>
            <textFocusedColor value="1 1 1 1"/>
            <textHighlightedColor value="1 1 1 1"/>
            <textDisabledColor value="$preset_colorDisabled"/>
        </Profile>

        <Profile name="dr_listSlider" extends="fs25_listSliderBox" with="anchorTopRight">
            <position value="50px -40px"/>
            <size value="6px 640px"/>
        </Profile>

        <Profile name="dr_tableHeader" extends="baseReference">
            <imageColor value="0 0 0 0"/>
            <textFocusedColor value="$preset_fs25_colorMainHighlight"/>
            <textHighlightedColor value="$preset_fs25_colorMainHighlight"/>
            <textSize value="16px"/>
            <textBold value="true"/>
            <textUpperCase value="true"/>
            <textColor value="$preset_colorWhite_50"/>
            <textAlignment value="left"/>
            <textDisabledColor value="$preset_colorDisabled"/>
        </Profile>

        <Profile name="dr_loanTable" extends="emptyPanel" with="anchorStretchingYLeft pivotTopLeft"/>

        <Profile name="dr_loanListItem" extends="baseReference" with="anchorTopStretchingX alternating">
            <height value="32px"/>
            <imageColor value="$preset_fs25_colorGrey"/>
            <imageSelectedColor value="$preset_fs25_colorMainHighlight"/>
            <alternateBackgroundColor value="$preset_fs25_colorGreyDark_50"/>
        </Profile>

        <Profile name="dr_loanRowCell" extends="baseReference" with="anchorStretchingYLeft">
            <textBold value="false"/>
            <textSize value="15px"/>
            <textAlignment value="left"/>
            <textColor value="$preset_fs25_colorMainLight"/>
            <textSelectedColor value="$preset_fs25_colorMainDark"/>
            <textDisabledColor value="$preset_colorDisabled"/>
        </Profile>

    </GUIProfiles>

</GUI>