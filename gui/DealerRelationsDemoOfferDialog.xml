<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI onOpen="onOpen" onClose="onClose" onCreate="onCreate">

    <GuiElement profile="fs25_textInputDialogBg" id="dialogElement" size="700px 430px">
        <ThreePartBitmap profile="fs25_dialogBgMiddleSmall" />
        <ThreePartBitmap profile="fs25_dialogBgTopSmall" />
        <ThreePartBitmap profile="fs25_dialogBgBottom" />

        <GuiElement profile="fs25_dialogContentContainer">
            <Text profile="fs25_textInputDialogText" id="dialogTitleElement" position="0px -40px" text="Dealer Demo Offer"/>
            <Text profile="fs25_textInputDialogText" id="messageTextElement" position="0px -95px" size="620px 260px" text=""/>
        </GuiElement>

        <BoxLayout profile="fs25_dialogButtonBox">
            <Button profile="buttonOK" text="Accept" onClick="onClickAccept" />
            <Button profile="buttonMenuSwitch" text="Decline" onClick="onClickDecline" />
            <Button profile="buttonBack" text="Cancel" onClick="onClickCancel" focusInit="onOpen" />
        </BoxLayout>

    </GuiElement>
        
</GUI>